        },
        "end":
        {
            "title":
            {
                "nl":"Sessie beëindigen",
                "en":"End session"
            },
            "text_1":
            {
                "nl":"Klik op de knop \"Afsluiten\" om de sessie te beëindigen\nen je Solis-id uit te loggen.\n\n\nAls er nog video's bezig zijn met uploaden naar OneDrive,\ndan zal hier op worden gewacht.\n\n\nDaarna zal de computer automatisch worden afgesloten.",
                "en":"Click \"Shut down\" to end the session and to logout your Solis-id.\n\n\nAny remaining file uploads to OneDrive will be completed.\n\n\nThe computer will automatically shut down afterwards."
            },
            "button_exit":
            {
                "nl":"Afsluiten",
                "en":"Shut down"
            }
        },
        "black":
        {
            "title":
            {
                "nl":"Aan het afsluiten.\nDit kan even duren.",
                "en":"Shutting down.\nThis might take a while."
            },
            "text_1":
            {
                "nl":"video(s) nog aan het uploaden.",
                "en":"remaining upload(s)."
            },
            "text_2":
            {
                "nl":"video(s) nog aan het versleutelen.",
                "en":"remaining file(s) to encrypt."
            }
