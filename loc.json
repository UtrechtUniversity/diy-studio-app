            },
            "text_1_recording":
            {
                "nl":"Bezig met opnemen",
                "en":"Recording in progress"
            },
            "text_1_processing":
            {
                "nl":"Bezig met verwerken",
                "en":"Finalising video"
            },
            "text_2":
            {
                "nl":"Druk op de stopknop op het bedieningspaneel\nom de opname te stoppen.",
                "en":"Press the stopbutton on the control panel\nto stop the recording."
