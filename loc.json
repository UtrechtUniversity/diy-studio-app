    "pagetext":
    {
        "login":
        {
            "title":
            {
                "nl":"Welkom in de Presenter DIY-studio",
                "en":"Welcome in the Presenter DIY-studio"
            },
            "text_1":
            {
                "nl":"Klik op Start om te beginnen.\n\nHierna kun je inloggen bij Microsoft met je Solis-id\nzodat de opnamesessie gekoppeld kan worden\naan je OneDrive.",
                "en":"Click on Start to begin.\n\nYou can then log in to Microsoft with your Solis-id\nso that the recording session can be linked\nto your OneDrive."
            },
            "text_2":
            {
                "nl":"Moment geduld, alstublieft.",
                "en":"One moment, please."
            },
            "text_3":
            {
                "nl":"Je bent ingelogd.",
                "en":"You are logged in."
            },
            "text_4":
            {
                "nl":"Er worden nog bestanden naar OneDrive geupload.\nJe kunt pas uitloggen wanneer dit voltooid is.",
                "en":"Files are being uploaded to OneDrive.\nYou can log out when this is finished."
            },
            "text_5":
            {
                "nl":"De inlogpoging werd onderbroken.\nProbeer opnieuw in te loggen.",
                "en":"Attempt to login was interrupted.\nPlease try to login again."
            },
            "text_6":
            {
                "nl":"Er ging iets mis tijdens het inloggen.\nProbeer opnieuw in te loggen.",
                "en":"Something went wrong while logging in.\nPlease try to login again."
            },
            "text_7":
            {
                "nl":"De inlogprocedure zal worden herstart in: ",
                "en":"Authentication will restart in: "
            }
        },
        "tutorial":
        {
            "title":
            {
                "nl":"Bekijk de tutorialvideo",
                "en":"Watch the tutorial video"
            }
        },
        "videotype_1":
        {
            "title":
            {
                "nl":"Kies een videotype",
                "en":"Choose a videotype"
            },
            "option_1":
            {
                "nl":"Video met achtergrond naar keuze",
                "en":"Video with background of your choice"
            },
            "option_2":
            {
                "nl":"Video met PowerPointpresentatie als achtergrond",
                "en":"Video with PowerPoint presentation as background"
            },
            "option_gs":
            {
                "nl":"Greenscreen-opname",
                "en":"Green screen recording"
            }
        },
        "videotype_2":
        {
            "title":
            {
                "nl":"Kies een achtergrond",
                "en":"Choose a background"
            }
        },
        "powerpoint_staticbg":
        {
            "title":
            {
                "nl":"(optioneel) Kies een PowerPointpresentatie",
                "en":"(optional) Choose a PowerPoint presentation"
            },
            "text_1":
            {
                "nl":"Kies rechts een presentatie uit je OneDrive.",
                "en":"Choose a presentation from your OneDrive."
            }
        },
        "powerpoint_ppt":
        {
            "title":
            {
                "nl":"Kies een PowerPointpresentatie",
                "en":"Choose a PowerPoint presentation"
            },
            "text_1":
            {
                "nl":"Kies rechts een presentatie uit je OneDrive.",
                "en":"Choose a presentation from your OneDrive."
            }
        },
        "calibration_1":
        {
            "title":
            {
                "nl":"Calibratie: bureauhoogte instellen",
                "en":"Calibration: setup desk height"
            },
            "texttitle_1":
            {
                "nl":"Hoogte instellen",
                "en":"Adjusting height"
            },
            "text_1":
            {
                "nl":"Zet het bureau hoger of lager met de (fysieke) knoppen aan de rechterkant van het bureaublad.",
                "en":"Raise or lower the desk using the (physical) buttons on the right side of the desk."
            },
            "texttitle_2":
            {
                "nl":"Correcte hoogte",
                "en":"Correct height"
            },
            "text_2":
            {
                "nl":"Zorg ervoor dat jouw ogen ongeveer op de blauwe lijn zitten op het scherm links wanneer je tegen de rode streep aan staat.",
                "en":"Ensure your eyes are approximately on the blue line on the screen on the left when you are standing against the red line."
            },
            "texttitle_3":
            {
                "nl":"Achtergrond",
                "en":"Background"
            },
            "text_3":
            {
                "nl":"De achtergrond wordt tijdelijk zwart. De gekozen achtergrond zal wel zichtbaar zijn in de video.",
                "en":"The background temporarily becomes black. The chosen background will be visible in the video."
            }
        },
        "calibration_2":
        {
            "title":
            {
                "nl":"Calibratie: soundcheck",
                "en":"Calibration: soundcheck"
            },
            "text_1":
            {
                "nl":"Ga tegen de rode streep aan staan en praat een moment op normaal volume.\n\nHet vierkant rechts kleurt groen als het geluid in orde is.",
                "en":"Stand before the red line and talk a moment on normal volume.\n\nThe square on the right changes color to green when the volume is optimal."
            }
        },
        "calibration_help":
        {
            "title":
            {
                "nl":"Calibratie help",
                "en":"Calibration help"
            }
        },
        "controls_1":
        {
            "title":
            {
                "nl":"Besturing",
                "en":"Controls"
            },
            "text_1":
            {
                "nl":"Dit is de controller waarmee je je PowerPointpresentatie bedient en opnames kunt starten en stoppen.",
                "en":"This is the controller for the PowerPoint-presentation and to start and stop the recording."
            }
        },
        "controls_2":
        {
            "title":
            {
                "nl":"Besturing",
                "en":"Controls"
            },
            "text_1":
            {
                "nl":"Met deze knoppen kun je door je PowerPointpresentatie bladeren.",
                "en":"With these buttons you can nagivate your PowerPoint presentation."
            }
        },
        "controls_3":
        {
            "title":
            {
                "nl":"Besturing",
                "en":"Controls"
            },
            "text_1":
            {
                "nl":"Met deze knop kun je opnames starten en stoppen.",
                "en":"With this button you can start and stop recordings."
            }
        },
        "record_overview":
        {
            "title":
            {
                "nl":"Overzicht van gemaakte opnames",
                "en":"Overview of recorded videos"
            },
            "texttitle_1a":
            {
                "nl":"Gereed",
                "en":"Ready"
            },
            "texttitle_1b":
            {
                "nl":"Upload",
                "en":"Upload"
            },
            "text_1a":
            {
                "nl":"Je bent klaar om op te nemen. Tijdens de opname zie je jezelf niet, maar je wordt wel opgenomen.",
                "en":"You are ready to record. You will not see yourself during the recording, but you will be recorded."
            },
            "text_1b":
            {
                "nl":"Als je de opname hebt goedgekeurd, dan wordt deze nu geupload naar jouw OneDrive.",
                "en":"If you accepted the recording, your video is now being uploaded to your OneDrive."
            },
            "texttitle_2a":
            {
                "nl":"Opname starten",
                "en":"Start recording"
            },
            "texttitle_2b":
            {
                "nl":"Nieuwe opname",
                "en":"New recording"
            },
            "text_2a":
            {
                "nl":"Druk op de opnameknop op het bedieningspaneel om de opname te starten.",
                "en":"Press the record button on the control panel to start recording."
            },
            "text_2b":
            {
                "nl":"Druk op de opnameknop op het bedieningspaneel om nog een opname te starten.",
                "en":"Press the record button on the control panel to start another recording."
            },
            "texttitle_3":
            {
                "nl":"Instellingen wijzigen?",
                "en":"Change settings?"
            },
            "text_3":
            {
                "nl":"Je kunt terugkeren naar eerdere pagina's via de knoppenbalk bovenin.",
                "en":"You can return to previous pages using the toolbar at the top of the screen."
            },
            "text_4":
            {
                "nl":"Alle opnames die je goedkeurt\nzullen hier verschijnen.\n\nDeze worden automatisch\nin de hoofdmap van\nje OneDrive geplaatst.",
                "en":"All recordings that you approve\nwill appear here.\n\nThese will be automatically\nplaced in the root folder\nof your OneDrive."
            },
            "browser":
            {
                "dir_good":
                {
                    "nl":"Opgeslagen videos",
